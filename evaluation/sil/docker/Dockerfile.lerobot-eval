FROM mcr.microsoft.com/azureml/openmpi4.1.0-ubuntu22.04:20260409.v4@sha256:b52b483fa404be588d0a4c482866180dcb118f32a210c96b0dbe5d347c34cbd2

RUN apt-get update -qq && \
    apt-get install -y -qq ffmpeg git build-essential unzip python3-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY requirements-lerobot-infer.txt .
RUN pip install --no-cache-dir "uv==0.10.9" && \
    uv pip install -r requirements-lerobot-infer.txt --system

# Pre-download ResNet18 backbone weights (required by ACT policy, no internet at runtime)
RUN python3 -c "import torchvision; torchvision.models.resnet18(weights='IMAGENET1K_V1')"
