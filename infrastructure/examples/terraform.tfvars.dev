// =============================================================================
// Development Environment
// =============================================================================
// Minimal configuration with a single spot GPU pool.
// Uses public networking for easy access during development.
// =============================================================================

// Core Configuration
environment     = "dev"
location        = "westus3"
resource_prefix = "roboticsdev"
instance        = "001"

// Resource Group
should_create_resource_group = true

// AKS System Node Pool
system_node_pool_vm_size    = "Standard_D4ds_v5"
system_node_pool_node_count = 1

// Single spot GPU pool
node_pools = {
  gpu = {
    vm_size                 = "Standard_NV36ads_A10_v5"
    subnet_address_prefixes = ["10.0.7.0/24"]
    node_taints             = ["nvidia.com/gpu:NoSchedule", "kubernetes.azure.com/scalesetpriority=spot:NoSchedule"]
    gpu_driver              = "Install"
    node_labels = {
      "kubernetes.azure.com/scalesetpriority" = "spot"
    }
    priority            = "Spot"
    eviction_policy     = "Delete"
    should_enable_auto_scaling = true
    min_count           = 0
    max_count           = 1
    zones               = []
  }
}

// OSMO Backend Services
should_deploy_postgresql = true
should_deploy_redis      = true

// Network Security — Full Public for development
should_enable_private_endpoint    = false
should_enable_private_aks_cluster = false

should_enable_public_network_access     = true
should_add_current_user_key_vault_admin = true
should_enable_microsoft_defender        = false

// Observability — Disable Grafana and AMPLS to reduce cost
// should_deploy_grafana           = false
// should_deploy_monitor_workspace = true
// should_deploy_ampls             = false
// should_deploy_dce               = false
