<?xml version="1.0" encoding="UTF-8"?>
<testsuites>
  <testsuite name="docs/README.md" tests="3">
    <testcase name="https://example.com">
      <properties>
        <property name="url" value="https://example.com"/>
        <property name="status" value="alive"/>
        <property name="statusCode" value="200"/>
      </properties>
    </testcase>
    <testcase name="https://example.com/broken-page">
      <properties>
        <property name="url" value="https://example.com/broken-page"/>
        <property name="status" value="dead"/>
        <property name="statusCode" value="404"/>
      </properties>
    </testcase>
    <testcase name="https://example.com/ignored-link">
      <properties>
        <property name="url" value="https://example.com/ignored-link"/>
        <property name="status" value="ignored"/>
        <property name="statusCode" value="0"/>
      </properties>
    </testcase>
  </testsuite>
</testsuites>
