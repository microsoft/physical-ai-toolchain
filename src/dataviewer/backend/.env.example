# HMI Backend Environment Configuration
# Copy this file to .env and fill in your local values.

# ─────────────────────────────────────────────────────────────────────────────
# Storage backend
# ─────────────────────────────────────────────────────────────────────────────

# Active storage backend: local (default) | azure
# Use 'azure' to connect directly to Azure Blob Storage via DefaultAzureCredential
# or a SAS token. Use 'local' for local filesystem access via HMI_DATA_PATH.
HMI_STORAGE_BACKEND=local

# ─────────────────────────────────────────────────────────────────────────────
# Local storage (used when HMI_STORAGE_BACKEND=local)
# ─────────────────────────────────────────────────────────────────────────────

# Path to the directory containing datasets.
# Each subdirectory is treated as a dataset_id.
# Relative paths are resolved from this file's directory (backend/).
HMI_DATA_PATH=../../../datasets

# ─────────────────────────────────────────────────────────────────────────────
# Azure Blob Storage (required when HMI_STORAGE_BACKEND=azure)
# ─────────────────────────────────────────────────────────────────────────────

# Azure Storage account name (e.g. mystorageaccount)
# AZURE_STORAGE_ACCOUNT_NAME=

# Blob container that holds dataset files (videos, parquet, HDF5).
# Expected structure: {dataset_id}/meta/info.json, {dataset_id}/videos/...
# AZURE_STORAGE_DATASET_CONTAINER=datasets

# Blob container that holds annotation JSON files.
# Defaults to AZURE_STORAGE_DATASET_CONTAINER when not set.
# AZURE_STORAGE_ANNOTATION_CONTAINER=annotations

# SAS token for Azure Blob authentication.
# When not set, DefaultAzureCredential is used (managed identity,
# workload identity, Azure CLI, environment credentials — in that order).
# Recommended: leave unset in AKS / Container Apps and rely on MSI.
# AZURE_STORAGE_SAS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Server configuration (set for container deployments)
# ─────────────────────────────────────────────────────────────────────────────

# Host address for uvicorn to bind to.
# Use 0.0.0.0 in Docker / AKS so the server is reachable from outside the container.
# BACKEND_HOST=127.0.0.1

# Port for the backend API server.
# BACKEND_PORT=8000

# ─────────────────────────────────────────────────────────────────────────────
# CORS (set for container / cloud deployments)
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Add your frontend URL (e.g. https://dataviewer.example.com) for cloud deployments.
# Defaults to localhost dev ports when not set.
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ─────────────────────────────────────────────────────────────────────────────
# Test configuration (used by pytest integration tests)
# ─────────────────────────────────────────────────────────────────────────────

# Base path containing test datasets. Defaults to ../../datasets relative to tests/.
# TEST_DATASET_PATH=../datasets

# Dataset ID (subdirectory name) used by integration tests.
# Must exist under TEST_DATASET_PATH. Defaults to lerobot.
# TEST_DATASET_ID=lerobot

# ============================================================================
# Authentication (WS-20)
# ============================================================================

# Set to "true" to disable authentication and CSRF checks in local development.
# NEVER enable this in production.
DATAVIEWER_AUTH_DISABLED=true

# Set to "true" when the server is behind HTTPS (marks the csrf_token cookie Secure).
# Always set this to "true" in production.
DATAVIEWER_SECURE_COOKIES=false

# Authentication provider: "apikey" (default), "azure_ad", or "auth0".
DATAVIEWER_AUTH_PROVIDER=apikey

# --- API key provider ---
# Secret key that clients must send in the X-API-Key header.
DATAVIEWER_API_KEY=

# --- Azure AD / Entra ID provider (DATAVIEWER_AUTH_PROVIDER=azure_ad) ---
# Azure tenant ID (GUID).
DATAVIEWER_AZURE_TENANT_ID=
# Azure AD application (client) ID used as the JWT audience.
DATAVIEWER_AZURE_CLIENT_ID=

# --- Auth0 provider (DATAVIEWER_AUTH_PROVIDER=auth0) ---
# Auth0 tenant domain, e.g. "your-tenant.us.auth0.com".
DATAVIEWER_AUTH0_DOMAIN=
# Auth0 API audience (identifier), e.g. "https://api.dataviewer.example.com".
DATAVIEWER_AUTH0_AUDIENCE=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend MSAL Configuration (build-time, used by Vite)
# ─────────────────────────────────────────────────────────────────────────────

# Azure AD client ID for frontend MSAL authentication.
# Same value as DATAVIEWER_AZURE_CLIENT_ID.
# VITE_AZURE_CLIENT_ID=

# Azure AD tenant ID for frontend MSAL authentication.
# Same value as DATAVIEWER_AZURE_TENANT_ID.
# VITE_AZURE_TENANT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend Nginx Configuration (runtime)
# ─────────────────────────────────────────────────────────────────────────────

# Backend host for nginx reverse proxy.
# Docker Compose default: backend:8000. Override for Container Apps or other deployments.
# NGINX_BACKEND_HOST=backend:8000
